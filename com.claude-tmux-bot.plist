<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.claude-tmux-bot</string>
    <key>ProgramArguments</key>
    <array>
        <string>__CTB_LAUNCHER__</string>
    </array>
    <key>WorkingDirectory</key>
    <string>__CTB_WORKING_DIR__</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>__CTB_PATH__</string>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>__CTB_HOME__/.ctb/logs/ctb.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>__CTB_HOME__/.ctb/logs/ctb.stderr.log</string>
</dict>
</plist>
